{
  "name": "@appsolves/appscreen-mcp",
  "version": "1.0.2",
  "description": "MCP server for controlling the AppScreen App Store Screenshot Generator.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "author": {
    "name": "Kaan Gönüldinc",
    "email": "contact@appsolves.dev",
    "url": "https://appsolves.dev"
  },
  "homepage": "https://appsolves.github.io/appscreen-mcp/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AppSolves/appscreen-mcp.git",
    "directory": "mcp-server"
  },
  "bugs": {
    "url": "https://github.com/AppSolves/appscreen-mcp/issues"
  },
  "bin": {
    "appscreen-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run typecheck && npm run build",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "appscreen",
    "app-store",
    "screenshots",
    "screenshot-generator",
    "playwright",
    "codex",
    "claude"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "playwright": "^1.56.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}